# Environment Variables Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git - it contains sensitive credentials

# Decodo / SmartProxy (REQUIRED for --proxy ingest)
SMARTPROXY_USERNAME=user-your_username
SMARTPROXY_PASSWORD=your_password
SMARTPROXY_HOST=gate.decodo.com
# Residential rotating endpoint is typically port 7000.
# Sticky/session ports (10001-10010) also work if your plan exposes them.
SMARTPROXY_PORTS=7000
# Must be http for Decodo/SmartProxy gateways (https:// proxy URLs often fail)
SMARTPROXY_SCHEME=http

# Proxy Mode Settings
# Keep FORCE_LOCAL=false so --proxy / PROXY_ENABLED can work.
FORCE_LOCAL=false
FORCE_PROXY=false
PROXY_ENABLED=false

# UI freshness threshold for the last fully validated daily run.
INGEST_STALE_AFTER_HOURS=30
# Set to the deployed commit or release identifier when the host has no Git checkout.
YUNOBALL_CODE_VERSION=

# Other existing variables...
# (Add your other .env variables here)
