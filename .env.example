# Environment Variables Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git - it contains sensitive credentials

# SmartProxy Configuration (REQUIRED for proxy functionality)
SMARTPROXY_USERNAME=your_smartproxy_username
SMARTPROXY_PASSWORD=your_smartproxy_password
SMARTPROXY_HOST=gate.smartproxy.com
SMARTPROXY_PORTS=10001,10002,10003,10004,10005,10006,10007,10008,10009,10010

# Proxy Mode Settings
FORCE_LOCAL=false
FORCE_PROXY=false
PROXY_ENABLED=false

# Other existing variables...
# (Add your other .env variables here)
